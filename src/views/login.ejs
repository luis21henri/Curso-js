<%- include('includes/head')%>
<%- include('includes/nav')%>

<div class="container">
    
    <div class="row">
        <div class="col-12 my-5 text-center">
            <h1 class="display-1">Registrar/Login</h1>
            <p class="lead">Faça login ou crie sua conta abaixo</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-2"></div>
        <div class="col-lg-8">
            <%- include('includes/messages') %>
        </div>
        <div class="col-lg-2"></div>
    </div>
    <div class="row">
        
        <div class="col-lg-6 my-5"> 
            <h4>Faça seu cadastro</h4>
            <form class="form-cadastro" action="/login/register" method="POST">
                <input type="hidden" name="_csrf"  value="<%= csrfToken %>">
                <div class="mb-3">
                    <label>Seu email</label>
                    <input type="email" class="form-control" name="email" aria-describedby="emailHelp">
                </div>
                <div class="mb-3">
                    <label>Sua senha</label>
                    <input type="password" class="form-control" name="password" aria-describedby="emailHelp">
                </div>

                <button type="submit" class="btn btn-primary">Criar minha conta</button>
            </form>
        </div>
        
        <div class="col-lg-6 mb-4"> 
            <h4>Faça seu login</h4>
            <form class="form-login" action="/login/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3">
                    <label>Seu email</label>
                    <input type="email" class="form-control" name="email" aria-describedby="emailHelp">
                </div>
                <div class="mb-3">
                    <label>Sua senha</label>
                    <input type="password" class="form-control" name="password" aria-describedby="emailHelp">
                </div>

                <button type="submit" class="btn btn-primary">Entrar</button>
            </form>
        </div>

    </div>

</div>

<%- include('includes/footer')%>