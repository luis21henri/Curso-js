<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>
    <div class="col-lg-8 my-5">
      <h1 class="display-1 text-center">Minha Agenda</h1>
      <p class="text-center lead">Seus contatos estão logo abaixo.</p>

      <%- include('includes/messages') %>
    </div>
    
    <% if(contatos.length > 0) { %>
    <div class="table-responsive">
      <table class="table my-3 table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Nome</th>
            <th>Sobrenome</th>
            <th>E-mail</th>
            <th>Telefone</th>
            <th>Editar</th>
            <th>Excluir</th>
          </tr>
        </thead>
        <tbody>
          <% contatos.forEach(contato => { %>
            <tr>
              <td><%= contato.nome %></td>
              <td><%= contato.sobrenome %></td>
              <td><%= contato.email %></td>
              <td><%= contato.telefone %></td>
              <td><a href="/contato/index/<%= contato._id %>" class="btn btn-sm btn-outline-warning">Editar</a></td>
              <td><a href="/contato/delete/<%= contato._id %>" class="btn btn-danger">Delete</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="text-center lead my-5">Não existem contatos na sua agenda.</p>
    <% } %>

  </div>
</div>

<%- include('includes/footer') %>
